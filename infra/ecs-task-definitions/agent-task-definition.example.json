{
  "family": "guus-voice-agent-worker-task",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/guus-voice-agent-worker-task-role",
  "containerDefinitions": [
    {
      "name": "worker",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/guus-voice-agent-worker:<TAG>",
      "essential": true,
      "environment": [
        { "name": "LIVEKIT_URL", "value": "wss://<your-livekit-host>" },
        { "name": "OPENAI_REALTIME_VOICE", "value": "marin" }
      ],
      "secrets": [
        {
          "name": "LIVEKIT_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:guus/livekit"
        },
        {
          "name": "LIVEKIT_API_SECRET",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:guus/livekit"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:guus/openai"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/guus-voice-agent-worker-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
